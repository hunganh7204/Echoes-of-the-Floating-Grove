--- !u!114 &5616478036002536749
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6909484626341191397}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 446069f5ba5fb464aac0b224c1c57968, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: Tester 1
  greetingMessage: "Xin ch\xE0o, t\xF4i c\xF3 th\u1EC3 gi\xFAp b\u1EA1n di chuy\u1EC3n
    linh ho\u1EA1t."
  npcPersona: "B\u1EA1n l\xE0 m\u1ED9t chi\u1EBFn binh m\u1EDBi, b\u1EA1n s\u1EBD
    x\u01B0ng t\xF4i v\xE0 g\u1ECDi \u0111\u1ED1i ph\u01B0\u01A1ng l\xE0 b\u1EA1n,
    b\u1EA1n l\xE0 ng\u01B0\u1EDDi nhi\u1EC7t t\xECnh nh\u01B0ng c\xF3 ch\xFAt nh\xFAt
    nh\xE1t"
  npcLore: "\u0110\xE2y l\xE0 r\xECa khu r\u1EEBng kh\u1EDFi \u0111\u1EA7u, NPC h\u01B0\u1EDBng
    d\u1EABn t\xE2n th\u1EE7 c\xE1ch di chuy\u1EC3n.  N\u1EBFu ng\u01B0\u1EDDi ch\u01A1i
    h\u1ECFi c\xE1c c\xE2u h\u1ECFi kh\xE1c, h\xE3y t\xF9y bi\u1EBFn tr\u1EA3 l\u1EDDi
    theo \u0111\xFAng n\u1ED9i dung c\xE2u h\u1ECFi, kh\xF4ng c\u1EA7n h\u01B0\u1EDBng
    v\xE0o vi\u1EC7c ch\u1EC9 tr\u1EA3 l\u1EDDi c\xE1ch di chuy\u1EC3n.C\u1ED1 g\u1EAFng
    tr\u1EA3 l\u1EDDi ng\u1EAFn g\u1ECDn d\u01B0\u1EDBi 20 t\u1EEB.C\xE1ch di chuy\u1EC3n
    h\xE3y \u0111\u1EC3 ng\u01B0\u1EDDi ch\u01A1i ch\u1EE7 \u0111\u1ED9ng h\u1ECFi
    t\u1EDBi t\u1EEB di chuy\u1EC3n s\u1EBD tr\u1EA3 l\u1EDDi sau."
  fixedResponses:
  - keyword: "di chuy\u1EC3n"
    answer: "B\u1EA1n h\xE3y s\u1EED d\u1EE5ng c\xE1c ph\xEDm A,D \u0111\u1EC3 di
      chuy\u1EC3n tr\xE1i, ph\u1EA3i, ph\xEDm space s\u1EBD gi\xFAp b\u1EA1n nh\u1EA3y,
      nh\u1EA5n l\u1EA7n n\u1EEFa s\u1EBD th\u1EF1c hi\u1EC7n nh\u1EA3y k\xE9p. H\xE3y
      th\u1EED v\u01B0\u1EE3t qua c\xE1c h\u1ED1 s\xE2u b\xEAn kia \u0111i."
  - keyword: di chuyen
    answer: "B\u1EA1n h\xE3y s\u1EED d\u1EE5ng c\xE1c ph\xEDm A,D \u0111\u1EC3 di
      chuy\u1EC3n tr\xE1i, ph\u1EA3i, ph\xEDm space s\u1EBD gi\xFAp b\u1EA1n nh\u1EA3y,
      nh\u1EA5n l\u1EA7n n\u1EEFa s\u1EBD th\u1EF1c hi\u1EC7n nh\u1EA3y k\xE9p. H\xE3y
      th\u1EED v\u01B0\u1EE3t qua c\xE1c h\u1ED1 s\xE2u b\xEAn kia \u0111i."
  spriteRenderer: {fileID: 6451623367116164187}
  boxCollider: {fileID: 6758877767843469526}
